{
  "manifest_version": 3,
  "name": "BOB Extension",
  "version": "2.0.5",
  "description": "Billion of Balls",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}